{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Top 10 Most Sighted Species (BioBlitz Melbourne 2014)",
        "fontSize": 16,
        "font": "sans-serif",
        "anchor": "middle"
    },
    "width": 400,
    "height": 320,
    "data": {
        "url": "https://raw.githubusercontent.com/NikhilDepala/FIT2179-DataVis2/main/data/bioblitz.csv"
    },
    "transform": [
        {
            "filter": "datum['Common Name'] == 'Magpie-lark' || datum['Common Name'] == 'Common Myna, Indian Myna' || datum['Common Name'] == 'Silver Gull' || datum['Common Name'] == 'Red Wattlebird' || datum['Common Name'] == 'Rainbow Lorikeet' || datum['Common Name'] == 'Spotted Dove' || datum['Common Name'] == 'Rock Dove, Feral Pigeon' || datum['Common Name'] == 'Welcome Swallow' || datum['Common Name'] == 'Chestnut Teal' || datum['Common Name'] == 'Crested Pigeon'"
        },
        {
            "aggregate": [{"op": "count", "as": "count"}],
            "groupby": ["Common Name"]
        }
    ],
    "mark": {"type": "bar", "cornerRadiusEnd": 4},
    "encoding": {
        "y": {
            "field": "Common Name",
            "type": "nominal",
            "sort": "-x",
            "title": "Species",
            "axis": {"labelLimit": 200}
        },
        "x": {
            "field": "count",
            "type": "quantitative",
            "title": "Number of Sightings"
        },
        "color": {
            "field": "count",
            "type": "quantitative",
            "scale": {"scheme": "blues"},
            "legend": null
        },
        "tooltip": [
            {"field": "Common Name", "type": "nominal", "title": "Species"},
            {"field": "count", "type": "quantitative", "title": "Sightings"}
        ]
    }
}