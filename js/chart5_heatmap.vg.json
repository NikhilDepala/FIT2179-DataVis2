{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "How Was Wildlife Reported? (Taxa vs Reporting Method)",
        "fontSize": 16,
        "font": "sans-serif",
        "anchor": "middle"
    },
    "width": 450,
    "height": 200,
    "data": {
        "url": "https://raw.githubusercontent.com/NikhilDepala/FIT2179-DataVis2/main/data/bioblitz.csv"
    },
    "transform": [
        {
            "filter": "datum['Data Resource Name'] != null && datum['Data Resource Name'] != ''"
        },
        {
            "filter": "datum.Taxa == 'Bird' || datum.Taxa == 'Plant' || datum.Taxa == 'Insect' || datum.Taxa == 'Mammal' || datum.Taxa == 'Reptile'"
        },
        {
            "aggregate": [{"op": "count", "as": "count"}],
            "groupby": ["Taxa", "Data Resource Name"]
        },
        {
            "impute": "count",
            "key": "Data Resource Name",
            "groupby": ["Taxa"],
            "value": 0
        }
    ],
    "mark": {"type": "rect", "stroke": "white", "strokeWidth": 2},
    "encoding": {
        "y": {
            "field": "Taxa",
            "type": "nominal",
            "title": "Animal Group",
            "axis": {"labelFontSize": 12},
            "sort": ["Bird", "Plant", "Insect", "Mammal", "Reptile"]
        },
        "x": {
            "field": "Data Resource Name",
            "type": "nominal",
            "title": "Reporting Method",
            "axis": {
                "labelAngle": -25,
                "labelFontSize": 11,
                "labelLimit": 180
            }
        },
        "color": {
            "field": "count",
            "type": "quantitative",
            "title": "No. of Sightings",
            "scale": {
                "range": ["#edf8e9", "#a1d99b", "#74c476", "#31a354", "#006d2c"],
                "domainMin": 0
            },
            "legend": {
                "title": "No. of Sightings",
                "gradientLength": 150
            }
        },
        "tooltip": [
            {"field": "Taxa", "type": "nominal", "title": "Animal Group"},
            {"field": "Data Resource Name", "type": "nominal", "title": "Reporting Method"},
            {"field": "count", "type": "quantitative", "title": "Sightings"}
        ]
    },
    "config": {
        "axis": {"grid": false}
    }
}