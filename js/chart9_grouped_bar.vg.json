{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Melbourne vs Canberra — Wildlife by Animal Group",
        "fontSize": 16,
        "font": "sans-serif",
        "anchor": "middle"
    },
    "width": 500,
    "height": 350,
    "data": {
        "values": [
            {"animal_group": "Birds", "count": 312, "city": "Melbourne"},
            {"animal_group": "Plants", "count": 198, "city": "Melbourne"},
            {"animal_group": "Insects", "count": 87, "city": "Melbourne"},
            {"animal_group": "Mammals", "count": 24, "city": "Melbourne"},
            {"animal_group": "Reptiles", "count": 12, "city": "Melbourne"},
            {"animal_group": "Birds", "count": 311, "city": "Canberra"},
            {"animal_group": "Mammals", "count": 5213, "city": "Canberra"},
            {"animal_group": "Reptiles", "count": 201, "city": "Canberra"}
        ]
    },
    "mark": {"type": "bar", "cornerRadiusEnd": 4},
    "encoding": {
        "x": {
            "field": "city",
            "type": "nominal",
            "title": null,
            "axis": {"labelFontSize": 12}
