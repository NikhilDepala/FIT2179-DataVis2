{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Melbourne vs Canberra Wildlife by Animal Group",
        "fontSize": 16,
        "font": "sans-serif",
        "anchor": "middle"
    },
    "width": "container",
    "height": 300,
    "data": {
        "values": [
            {"animal_group": "Birds",    "count": 312,  "city": "Melbourne (Sightings)"},
            {"animal_group": "Plants",   "count": 198,  "city": "Melbourne (Sightings)"},
            {"animal_group": "Insects",  "count": 87,   "city": "Melbourne (Sightings)"},
            {"animal_group": "Mammals",  "count": 24,   "city": "Melbourne (Sightings)"},
            {"animal_group": "Reptiles", "count": 12,   "city": "Melbourne (Sightings)"},
            {"animal_group": "Birds",    "count": 311,  "city": "Canberra (Incidents)"},
            {"animal_group": "Mammals",  "count": 5213, "city": "Canberra (Incidents)"},
            {"animal_group": "Reptiles", "count": 201,  "city": "Canberra (Incidents)"}
        ]
    },
    "mark": {"type": "bar", "cornerRadiusTopLeft": 4, "cornerRadiusTopRight": 4},
    "encoding": {
        "x": {
            "field": "animal_group",
            "type": "nominal",
            "title": "Animal Group",
            "axis": {"labelFontSize": 12}
        },
        "y": {
            "field": "count",
            "type": "quantitative",
            "title": "Count",
            "axis": {"labelFontSize": 11}
        },
        "xOffset": {
            "field": "city",
            "type": "nominal"
        },
        "color": {
            "field": "city",
            "type": "nominal",
            "title": "City & Data Type",
            "scale": {
                "domain": ["Melbourne (Sightings)", "Canberra (Incidents)"],
                "range": ["#2d6a4f", "#e63946"]
            }
        },
        "tooltip": [
            {"field": "animal_group", "type": "nominal",      "title": "Animal Group"},
            {"field": "city",         "type": "nominal",      "title": "City"},
            {"field": "count",        "type": "quantitative", "title": "Count", "format": ","}
        ]
    },
    "config": {
        "axis": {"grid": false}
    }
}