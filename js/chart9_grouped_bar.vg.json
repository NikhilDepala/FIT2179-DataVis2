        },
        "column": {
            "field": "animal_group",
            "type": "nominal",
            "title": "Animal Group",
            "header": {"labelFontSize": 12, "titleFontSize": 13}
        },
        "tooltip": [
            {"field": "animal_group", "type": "nominal", "title": "Animal Group"},
            {"field": "city", "type": "nominal", "title": "City"},
            {"field": "count", "type": "quantitative", "title": "Count", "format": ","}
        ]
    },
    "config": {
        "view": {"stroke": null},
        "axis": {"grid": false}
    }
